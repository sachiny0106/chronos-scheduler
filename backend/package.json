{
  "name": "chronos-scheduler",
  "version": "1.0.0",
  "description": "Distributed task scheduler with leader election, Redis Streams consumer groups, and fault tolerance",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "concurrently -n api,sched,worker -c blue,yellow,green \"tsx watch src/index.ts\" \"tsx watch src/scheduler.ts\" \"tsx watch src/worker.ts\"",
    "dev:api": "tsx watch src/index.ts",
    "dev:scheduler": "tsx watch src/scheduler.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start:api": "node dist/index.js",
    "start:scheduler": "node dist/scheduler.js",
    "start:worker": "node dist/worker.js",
    "seed": "tsx scripts/seed-tenant.ts",
    "load-test": "tsx scripts/load-test.ts",
    "chaos-test": "tsx scripts/chaos-test.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "distributed",
    "task-scheduler",
    "redis-streams",
    "leader-election",
    "job-queue"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "ioredis": "^5.4.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.9.5",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
