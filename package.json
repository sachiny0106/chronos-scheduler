{
  "name": "chronos-scheduler",
  "version": "1.0.0",
  "description": "Distributed task scheduler with leader election, Redis Streams consumer groups, and fault tolerance",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev:api": "tsx watch src/index.ts",
    "dev:scheduler": "tsx watch src/scheduler.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start:api": "node dist/index.js",
    "start:scheduler": "node dist/scheduler.js",
    "start:worker": "node dist/worker.js",
    "seed": "tsx scripts/seed-tenant.ts",
    "load-test": "tsx scripts/load-test.ts",
    "chaos-test": "tsx scripts/chaos-test.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": ["distributed", "task-scheduler", "redis-streams", "leader-election", "job-queue"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.1",
    "ioredis": "^5.4.2",
    "mongoose": "^8.9.5",
    "zod": "^3.24.1",
    "cron-parser": "^4.9.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.5",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0"
  }
}
